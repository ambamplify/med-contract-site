{
  "name": "medcontractintel",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "tsx watch server/index.ts",
    "dev:client": "vite",
    "build": "vite build && esbuild server/index.ts --bundle --platform=node --format=esm --outfile=dist/index.mjs --packages=external && cp -r public dist/public && mkdir -p dist/server && cp -r server/pdfs dist/server/pdfs",
    "start": "NODE_ENV=production node dist/index.mjs"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@sentry/node": "^8.47.0",
    "better-sqlite3": "^11.7.0",
    "cors": "^2.8.5",
    "docx": "^9.0.0",
    "dotenv": "^17.4.0",
    "drizzle-orm": "^0.38.0",
    "express": "^4.21.0",
    "jspdf": "^2.5.2",
    "multer": "^1.4.5-lts.1",
    "pdf-parse": "^1.1.1",
    "stripe": "^22.0.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.0",
    "drizzle-kit": "^0.30.0",
    "esbuild": "^0.24.0",
    "lucide-react": "^0.469.0",
    "postcss": "^8.4.49",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^7.1.0",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0"
  }
}
